{
  "version": 1,
  "sdk_version": "0.20.1",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://iyrhhoacnyltbtzonxwi.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "book-dine-find-mcp",
      "version": "0.1.0",
      "title": "Book, Dine & Find"
    },
    "tools": [
      {
        "name": "list_published_businesses",
        "title": "List published businesses",
        "description": "List published businesses in the directory. Optionally filter by city, kind (restaurant/service), or a text search on name.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "city": {
              "description": "Filter by city name.",
              "type": "string"
            },
            "kind": {
              "description": "Filter by business kind.",
              "type": "string",
              "enum": [
                "restaurant",
                "service"
              ]
            },
            "search": {
              "description": "Case-insensitive substring match on the business name.",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return. Default 20.",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_my_bookings",
        "title": "List my bookings",
        "description": "List bookings belonging to the signed-in user, most recent first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Filter by booking status.",
              "type": "string",
              "enum": [
                "pending",
                "confirmed",
                "cancelled",
                "completed"
              ]
            },
            "limit": {
              "description": "Max rows to return. Default 20.",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "cancel_booking",
        "title": "Cancel booking",
        "description": "Cancel one of the signed-in user's bookings by id. Sets status to 'cancelled'.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "booking_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The booking id to cancel."
            }
          },
          "required": [
            "booking_id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
